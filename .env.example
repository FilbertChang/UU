# PostgreSQL (consumed by the db service in docker-compose.yml)
POSTGRES_USER=legalai
POSTGRES_PASSWORD=changeme
POSTGRES_DB=legalai

# Backend connection string (host "db" = the compose service name)
DATABASE_URL=postgresql+psycopg2://legalai:changeme@db:5432/legalai

# Host port the backend is published on. Change this if 8000 is already
# taken on your machine (the container always listens on 8000 internally).
BACKEND_PORT=8000

# LLM provider: "ollama" (local) or "openai" (API).
LLM_PROVIDER=ollama

# Ollama — used when LLM_PROVIDER=ollama.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:latest

# OpenAI — used when LLM_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Set to false to disable the cross-encoder reranker (saves memory/CPU).
RERANKER_ENABLED=true
